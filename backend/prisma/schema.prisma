// schema.prisma
// Vehicle Rental Marketplace — Neon (PostgreSQL) + Prisma

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Make {
  Toyota
  Honda
  BYD
  Nissan
  Suzuki
  Ford
  BMW
  Mercedes
  Audi
  Tata
  Kia
  Tesla
  Volkswagen
}

enum District {
  Colombo
  Gampaha
  Kandy
  Galle
  Jaffna
  Trincomalee
  Anuradhapura
  Kurunegala
}

enum BodyType {
  Sedan
  SUV
  Truck
  Coupe
  Van
  Hatchback
}

enum FuelType {
  Petrol
  Diesel
  Electric
  Hybrid
}

enum RentalRequestStatus {
  pending
  accepted
  denied
}

enum TransmissionType {
  Automatic
  Manual
}

enum ListingStatus {
  active
  inactive
  rented
  deleted
}

enum OrderStatus {
  active
  ending_soon
  completed
}

enum MessageType {
  text
  rental_request
  rental_accepted
  rental_denied
}

// ─────────────────────────────────────────────
// User
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings  Listing[]
  orders    Order[]
  ownerChats    Chat[]       @relation("OwnerChats")
  chatUserChats Chat[]       @relation("ChatUserChats")
  messages  Message[]
}

// ─────────────────────────────────────────────
// Listing
// ─────────────────────────────────────────────

model Listing {
  id                String          @id @default(cuid())
  ownerId           String
  title             String
  make              Make
  model             String
  year              Int
  trim              String?
  body_type         BodyType
  exterior_color    String
  interior_color    String?
  horsepower        Int
  doors             Int?
  fuel_type         FuelType
  cylinders         Int?
  engine_capacity_cc Int?
  battery_capacity_kwh Float?
  range_km          Int?
  seating_capacity  Int
  transmission_type TransmissionType
  mileage_km        Int
  price_per_day     Float
  deposit           Float?
  min_rental_days   Int             @default(1)
  max_rental_days   Int             @default(30)
  description       String
  available         Boolean         @default(true)
  city              String
  district          District
  status            ListingStatus   @default(active)
  images            String[]        // Array of image URLs
  platformAssured   Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  owner    User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  orders   Order[]
  chats    Chat[]
  rentalRequests RentalRequest[]
}

// ─────────────────────────────────────────────
// Order
// ─────────────────────────────────────────────

model Order {
  id           String      @id @default(cuid())
  listingId    String
  ownerId      String
  userId       String
  price_per_day Float
  rental_start DateTime
  rental_end   DateTime
  status       OrderStatus @default(active)
  isPaid       Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Chat & Messages
// ─────────────────────────────────────────────

model Chat {
  id                  String    @id @default(cuid())
  listingId           String
  chatUserId              String    // renter
  ownerUserId             String    // listing owner
  messages            Message[]
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  active              Boolean   @default(true)
  lastMessage         String    @default("")
  isLastMessageRead   Boolean   @default(true)
  lastMessageSenderId String    @default("")

  listing  Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  ownerUser User    @relation("OwnerChats", fields: [ownerUserId], references: [id])
  chatUser  User    @relation("ChatUserChats", fields: [chatUserId], references: [id])
  rentalRequests RentalRequest[]
}

model Message {
  id        String      @id @default(cuid())
  chatId    String
  message   String
  senderId  String
  type      MessageType @default(text)
  createdAt DateTime    @default(now())

  chat Chat @relation(fields: [chatId], references: [id])
  sender User @relation(fields: [senderId], references: [id])
}
model RentalRequest {
  id        String   @id @default(cuid())
  chatId    String
  listingId String
  renterId  String
  ownerId   String
  status    RentalRequestStatus @default(pending)
  rentalStart DateTime
  rentalEnd   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chat    Chat    @relation(fields: [chatId], references: [id])
  listing Listing @relation(fields: [listingId], references: [id])
}


